{
  "name": "aws-opensource-mailserver",
  "version": "0.1.0",
  "private": true,
  "description": "AWS Open Source Mail Server Infrastructure",
  "scripts": {
    "format": "nx format:write",
    "format:check": "nx format:check",
    "cms:infra:up": "docker compose -f apps/cms-platform/docker-compose.local.yml up -d postgres minio localstack mailhog",
    "cms:infra:down": "docker compose -f apps/cms-platform/docker-compose.local.yml down",
    "cms:apps:serve": "pnpm nx run-many --target=serve --projects=cms-api,cms-worker,cms-web,cms-telephony-sim --parallel=4",
    "cms:compose:up": "docker compose -f apps/cms-platform/docker-compose.local.yml --profile apps up",
    "cms:seed": "pnpm exec tsx --tsconfig tools/tsconfig.json tools/cms-seed.cli.ts",
    "cms:scenario": "pnpm exec tsx --tsconfig tools/tsconfig.json tools/cms-bootstrap-scenario.cli.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.12.2",
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.926.0",
    "@aws-sdk/client-cloudwatch": "^3.966.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.982.0",
    "@aws-sdk/client-ec2": "^3.925.0",
    "@aws-sdk/client-iam": "^3.982.0",
    "@aws-sdk/client-kms": "^3.925.0",
    "@aws-sdk/client-lambda": "^3.966.0",
    "@aws-sdk/client-route-53": "^3.925.0",
    "@aws-sdk/client-s3": "^3.925.0",
    "@aws-sdk/client-ses": "^3.966.0",
    "@aws-sdk/client-sns": "^3.982.0",
    "@aws-sdk/client-ssm": "^3.925.0",
    "@aws-sdk/lib-storage": "^3.925.0",
    "@babel/core": "^7.28.5",
    "@nx/esbuild": "^22.0.2",
    "@nx/eslint": "^22.0.2",
    "@nx/eslint-plugin": "^22.0.2",
    "@nx/jest": "^22.0.2",
    "@nx/js": "^22.0.2",
    "@nx/node": "^22.0.2",
    "@nx/vite": "22.0.2",
    "@nx/web": "22.0.2",
    "@nx/workspace": "^22.0.2",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@types/jest": "^29.5.12",
    "@types/node": "20.19.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "aws-cdk": "^2.150.0",
    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.19.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "imapflow": "^1.1.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-util": "^29.7.0",
    "jiti": "2.4.2",
    "jsdom": "^26.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "^22.0.2",
    "prettier": "^3.3.3",
    "tar": "^7.5.2",
    "ts-jest": "^29.1.5",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-sts": "^3.654.0",
    "@aws-sdk/credential-providers": "^3.654.0",
    "ini": "^4.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
