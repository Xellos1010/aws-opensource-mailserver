      "Key": "Environment",
      "Value": "dev"
     },
     {
      "Key": "ManagedBy",
      "Value": "Nx+CDK"
     }
    ],
    "Timeout": 30
   },
   "DependsOn": [
    "SmtpLambdaExecutionRoleDefaultPolicyADB7C956",
    "SmtpLambdaExecutionRole0CC82604"
   ],
   "Metadata": {
    "aws:cdk:path": "emcnotary-com-mailserver-core/SmtpLambdaFunction/Resource"
   }
