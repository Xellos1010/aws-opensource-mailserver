{
  "name": "infra-config-loader",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/infra/config-loader/src",
  "projectType": "library",
  "tags": ["type:util", "scope:infra", "domain:config"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p libs/infra/config-loader/tsconfig.lib.json",
          "tsc -p libs/infra/config-loader/bin/tsconfig.json"
        ],
        "parallel": false
      },
      "outputs": ["{workspaceRoot}/dist/libs/infra/config-loader"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/infra/config-loader/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}

