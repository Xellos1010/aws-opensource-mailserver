{
  "name": "infra-config-loader",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/infra/config-loader/src",
  "projectType": "library",
  "tags": ["type:util", "scope:infra", "domain:config"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/infra/config-loader",
        "main": "libs/infra/config-loader/src/index.ts",
        "tsConfig": "libs/infra/config-loader/tsconfig.lib.json",
        "assets": [
          "libs/infra/config-loader/*.md"
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/infra/config-loader/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}

