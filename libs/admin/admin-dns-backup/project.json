{
  "name": "admin-dns-backup",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-dns-backup/src",
  "projectType": "library",
  "tags": ["type:script", "scope:aws", "domain:dns"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-dns-backup",
        "main": "libs/admin/admin-dns-backup/src/lib/backup.ts",
        "outputFileName": "dns-backup.js",
        "bundle": true,
        "platform": "node",
        "tsConfig": "libs/admin/admin-dns-backup/tsconfig.lib.json"
      }
    },
    "backup": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-dns-backup/dns-backup.js"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-dns-backup/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
