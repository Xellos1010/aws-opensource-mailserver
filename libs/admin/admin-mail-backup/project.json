{
  "name": "admin-mail-backup",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-mail-backup/src",
  "projectType": "library",
  "tags": ["type:script", "scope:mail", "domain:backup"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-mail-backup",
        "main": "libs/admin/admin-mail-backup/bin/mail-backup.ts",
        "outputFileName": "mail-backup.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/admin/admin-mail-backup/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "backup": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-mail-backup/mail-backup.mjs"
      }
    },
    "backup:sampletenant": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=your-aws-profile AWS_REGION=us-east-1 APP_PATH=apps/clients/cdk-client-example node dist/libs/admin/admin-mail-backup/mail-backup.mjs"
      }
    },
    "backup:mailexample": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=your-aws-profile AWS_REGION=us-east-1 APP_PATH=apps/clients/cdk-client-example node dist/libs/admin/admin-mail-backup/mail-backup.mjs"
      }
    },
    "backup:apps:cdk-client-example": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=your-aws-profile AWS_REGION=us-east-1 APP_PATH=apps/clients/cdk-client-example node dist/libs/admin/admin-mail-backup/mail-backup.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-mail-backup/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
