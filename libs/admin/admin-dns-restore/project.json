{
  "name": "admin-dns-restore",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-dns-restore/src",
  "projectType": "library",
  "tags": ["scope:aws", "type:util", "domain:dns"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-dns-restore",
        "main": "libs/admin/admin-dns-restore/bin/restore-miab.ts",
        "outputFileName": "restore-miab.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/admin/admin-dns-restore/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "restore": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-dns-restore/dns-restore.mjs"
      }
    },
    "restore:askdaokapra": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "NODE_TLS_REJECT_UNAUTHORIZED=0 AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 BACKUP_FILE=dist/backups/askdaokapra/dns/2025-09-15T12-02-36-000Z/dns-backup-20250915-120236.json APP_PATH=apps/cdk-askdaokapra DRY_RUN=0 node dist/libs/admin/admin-dns-restore/restore-miab.mjs"
      }
    },
    "restore:askdaokapra:dry-run": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "NODE_TLS_REJECT_UNAUTHORIZED=0 AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 BACKUP_FILE=dist/backups/askdaokapra/dns/2025-09-15T12-02-36-000Z/dns-backup-20250915-120236.json APP_PATH=apps/cdk-askdaokapra DRY_RUN=1 node dist/libs/admin/admin-dns-restore/restore-miab.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-dns-restore/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
