{
  "name": "admin-stack-info",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-stack-info/src",
  "projectType": "library",
  "tags": ["scope:aws", "type:util", "domain:infra"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-stack-info",
        "main": "libs/admin/admin-stack-info/bin/get-stack-info.ts",
        "outputFileName": "get-stack-info.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/admin/admin-stack-info/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "get": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-stack-info/get-stack-info.mjs"
      }
    },
    "get:emcnotary": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-emc-notary node dist/libs/admin/admin-stack-info/get-stack-info.mjs"
      }
    },
    "get:base": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 node dist/libs/admin/admin-stack-info/get-stack-info.mjs"
      }
    },
    "emcnotary:get": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-emc-notary node dist/libs/admin/admin-stack-info/get-stack-info.mjs"
      }
    },
    "base:get": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 node dist/libs/admin/admin-stack-info/get-stack-info.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-stack-info/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
