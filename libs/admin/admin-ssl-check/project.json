{
  "name": "admin-ssl-check",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-ssl-check/src",
  "projectType": "library",
  "tags": ["type:script", "scope:admin", "domain:ssl"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-ssl-check",
        "main": "libs/admin/admin-ssl-check/src/lib/check.ts",
        "outputFileName": "ssl-check.cjs",
        "bundle": true,
        "platform": "node",
        "format": ["cjs"],
        "tsConfig": "libs/admin/admin-ssl-check/tsconfig.lib.json"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-ssl-check/ssl-check.cjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-ssl-check/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
