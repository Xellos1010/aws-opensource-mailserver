{
  "name": "admin-s3-empty",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-s3-empty/src",
  "projectType": "library",
  "tags": ["scope:admin", "type:util", "platform:node"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-s3-empty",
        "main": "libs/admin/admin-s3-empty/bin/empty-buckets.ts",
        "tsConfig": "libs/admin/admin-s3-empty/tsconfig.lib.json",
        "assets": [],
        "format": ["esm"],
        "outputFileName": "empty-buckets.mjs",
        "generatePackageJson": true,
        "bundle": true,
        "platform": "node",
        "target": "node20",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-s3-empty/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "empty": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=${AWS_PROFILE:-hepe-admin-mfa} AWS_REGION=${AWS_REGION:-us-east-1} APP_PATH=${APP_PATH} STACK_NAME=${STACK_NAME} DOMAIN=${DOMAIN} DRY_RUN=${DRY_RUN:-0} node dist/libs/admin/admin-s3-empty/empty-buckets.mjs"
      }
    },
    "empty:emcnotary": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-emcnotary-core node dist/libs/admin/admin-s3-empty/empty-buckets.mjs"
      }
    },
    "empty:emcnotary:dry-run": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-emcnotary-core DRY_RUN=1 node dist/libs/admin/admin-s3-empty/empty-buckets.mjs"
      }
    },
    "empty:emcnotary:old-stack": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 STACK_NAME=emcnotary-mailserver-core node dist/libs/admin/admin-s3-empty/empty-buckets.mjs"
      }
    },
    "empty:askdaokapra": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-askdaokapra node dist/libs/admin/admin-s3-empty/empty-buckets.mjs"
      }
    },
    "empty:askdaokapra:dry-run": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-askdaokapra DRY_RUN=1 node dist/libs/admin/admin-s3-empty/empty-buckets.mjs"
      }
    }
  }
}

