{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "../../../dist/out-tsc",
    "rootDir": ".",
    "types": ["node"],
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*.ts", "bin/**/*.ts"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}

