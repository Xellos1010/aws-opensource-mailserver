{
  "name": "admin-kms",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-kms/src",
  "projectType": "library",
  "tags": ["type:script", "scope:aws", "domain:kms"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-kms",
        "main": "libs/admin/admin-kms/src/lib/kms.ts",
        "outputFileName": "kms.js",
        "bundle": true,
        "platform": "node",
        "tsConfig": "libs/admin/admin-kms/tsconfig.lib.json"
      }
    },
    "enable": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-kms/kms.js enable $KMS_KEY_ID"
      }
    },
    "disable": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-kms/kms.js disable $KMS_KEY_ID"
      }
    },
    "status": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-kms/kms.js status $KMS_KEY_ID"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-kms/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
