{
  "name": "admin-backup-bridge",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-backup-bridge/src",
  "projectType": "library",
  "tags": ["scope:aws", "type:script", "domain:backup"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-backup-bridge",
        "main": "libs/admin/admin-backup-bridge/bin/backup-bridge.ts",
        "outputFileName": "backup-bridge.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/admin/admin-backup-bridge/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "backup": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-backup-bridge/backup-bridge.mjs"
      }
    },
    "backup:emcnotary": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-emc-notary node dist/libs/admin/admin-backup-bridge/backup-bridge.mjs"
      }
    },
    "backup:apps:cdk-emc-notary": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-emc-notary node dist/libs/admin/admin-backup-bridge/backup-bridge.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-backup-bridge/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
