{
  "name": "ses-dns",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/ses-dns/src",
  "projectType": "library",
  "tags": ["scope:admin", "type:util", "domain:dns"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/ses-dns",
        "main": "libs/admin/ses-dns/bin/set-ses-dns.ts",
        "tsConfig": "libs/admin/ses-dns/tsconfig.lib.json",
        "assets": [],
        "format": ["esm"],
        "outputFileName": "set-ses-dns.mjs",
        "generatePackageJson": true,
        "bundle": true,
        "platform": "node",
        "target": "node20",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "set-dns": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/ses-dns/set-ses-dns.mjs"
      }
    },
    "set-dns:emcnotary": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/ses-dns/set-ses-dns.mjs --domain emcnotary.com"
      }
    },
    "set-dns:emcnotary:dry-run": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/ses-dns/set-ses-dns.mjs --domain emcnotary.com --dry-run"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
