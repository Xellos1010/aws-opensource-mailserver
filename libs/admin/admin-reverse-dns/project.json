{
  "name": "admin-reverse-dns",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-reverse-dns/src",
  "projectType": "library",
  "tags": ["scope:aws", "type:util", "domain:dns"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-reverse-dns",
        "main": "libs/admin/admin-reverse-dns/bin/set-reverse-dns.ts",
        "outputFileName": "set-reverse-dns.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/admin/admin-reverse-dns/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "set": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-reverse-dns/set-reverse-dns.mjs"
      }
    },
    "set:askdaokapra": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-askdaokapra node dist/libs/admin/admin-reverse-dns/set-reverse-dns.mjs"
      }
    },
    "set:emcnotary": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-emc-notary/core node dist/libs/admin/admin-reverse-dns/set-reverse-dns.mjs"
      }
    },
    "set:k3frame": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "AWS_PROFILE=hepe-admin-mfa AWS_REGION=us-east-1 APP_PATH=apps/cdk-k3frame/instance node dist/libs/admin/admin-reverse-dns/set-reverse-dns.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-reverse-dns/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
