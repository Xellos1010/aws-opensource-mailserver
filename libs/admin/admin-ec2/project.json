{
  "name": "admin-ec2",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-ec2/src",
  "projectType": "library",
  "tags": ["type:script", "scope:aws", "domain:ec2"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-ec2",
        "main": "libs/admin/admin-ec2/src/lib/ec2.ts",
        "outputFileName": "ec2.js",
        "bundle": true,
        "platform": "node",
        "tsConfig": "libs/admin/admin-ec2/tsconfig.lib.json"
      }
    },
    "build:bin": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-ec2",
        "main": "libs/admin/admin-ec2/bin/stop-and-start-instance.ts",
        "outputFileName": "stop-and-start-instance.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/admin/admin-ec2/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "restart": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-ec2/ec2.js restart $INSTANCE_ID"
      }
    },
    "stop": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-ec2/ec2.js stop $INSTANCE_ID"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-ec2/ec2.js start $INSTANCE_ID"
      }
    },
    "type": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-ec2/ec2.js type $INSTANCE_ID $INSTANCE_TYPE"
      }
    },
    "stop-and-start-instance": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:bin"],
      "options": {
        "command": "node dist/libs/admin/admin-ec2/stop-and-start-instance.mjs"
      }
    },
    "stop-and-start-instance:emcnotary": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:bin"],
      "options": {
        "command": "DOMAIN=emcnotary.com node dist/libs/admin/admin-ec2/stop-and-start-instance.mjs"
      }
    },
    "stop-and-start-instance:askdaokapra": {
      "executor": "nx:run-commands",
      "dependsOn": ["build:bin"],
      "options": {
        "command": "DOMAIN=askdaokapra.com node dist/libs/admin/admin-ec2/stop-and-start-instance.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-ec2/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
