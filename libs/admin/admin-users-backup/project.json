{
  "name": "admin-users-backup",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/admin/admin-users-backup/src",
  "projectType": "library",
  "tags": ["scope:aws", "type:util", "domain:admin"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/admin/admin-users-backup",
        "main": "libs/admin/admin-users-backup/bin/users-backup.ts",
        "outputFileName": "users-backup.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/admin/admin-users-backup/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "backup": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/libs/admin/admin-users-backup/users-backup.mjs"
      }
    },
    "backup:sampletenant": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "NODE_TLS_REJECT_UNAUTHORIZED=0 AWS_PROFILE=your-aws-profile AWS_REGION=us-east-1 APP_PATH=apps/clients/cdk-client-example node dist/libs/admin/admin-users-backup/users-backup.mjs"
      }
    },
    "backup:mailexample": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "NODE_TLS_REJECT_UNAUTHORIZED=0 AWS_PROFILE=your-aws-profile AWS_REGION=us-east-1 APP_PATH=apps/clients/cdk-client-example node dist/libs/admin/admin-users-backup/users-backup.mjs"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/admin/admin-users-backup/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
