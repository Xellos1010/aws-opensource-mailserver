{
  "name": "cms-contracts",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/cms/contracts/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:util", "domain:cms"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/cms/contracts",
        "main": "libs/cms/contracts/src/index.ts",
        "outputFileName": "index.mjs",
        "bundle": true,
        "platform": "node",
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/cms/contracts/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/cms/contracts/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
