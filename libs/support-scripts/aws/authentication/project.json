{
  "name": "authentication",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/support-scripts/aws/authentication/src",
  "projectType": "library",
  "tags": ["type:script", "scope:aws", "domain:auth"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/support-scripts/aws/authentication",
        "main": "libs/support-scripts/aws/authentication/bin/mfa-user.ts",
        "outputFileName": "mfa-user.mjs",
        "platform": "node",
        "bundle": true,
        "format": ["esm"],
        "target": "node20",
        "tsConfig": "libs/support-scripts/aws/authentication/tsconfig.lib.json",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        }
      }
    },
    "mfa": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/libs/support-scripts/aws/authentication/mfa-user.mjs"
      },
      "dependsOn": ["build"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/support-scripts/aws/authentication/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
