{
  "name": "cms-worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cms-worker/src",
  "projectType": "application",
  "tags": ["scope:shared", "type:tool", "domain:cms"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/cms-worker",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/cms-worker/src/main.ts",
        "outputFileName": "main.cjs",
        "tsConfig": "apps/cms-worker/tsconfig.app.json",
        "external": [],
        "generatePackageJson": true,
        "esbuildOptions": {
          "sourcemap": true,
          "logLevel": "silent"
        },
        "skipTypeCheck": true
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apps/cms-worker/tsconfig.app.json apps/cms-worker/src/main.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
