# === MFA (local, interactive) ===
MFA_DEVICE_ARN=arn:aws:iam::<YOUR_ACCOUNT_ID>:mfa/<YOUR_MFA_DEVICE>
SOURCE_PROFILE=<your-profile>
TARGET_PROFILE=<your-profile>
DURATION_SECONDS=43200
AWS_REGION=us-east-1
FEATURE_NX_SCRIPTS_ENABLED=1

# === DNS backup (Route53 -> optional S3) ===
DNS_BACKUP_BUCKET=
DNS_BACKUP_PREFIX=backups/dns/

# === Mail backup (IMAP -> tar.gz -> optional S3) ===
MAIL_HOST=mail.example.com
MAIL_PORT=993
MAIL_SECURE=1
MAIL_USER=user@example.com
MAIL_PASS=REPLACE_ME
MAIL_BACKUP_BUCKET=
MAIL_BACKUP_PREFIX=backups/mail/
MAIL_INCLUDE=INBOX,Sent
MAIL_EXCLUDE=Spam,Trash

# === EC2 admin ===
INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
INSTANCE_TYPE=t3.medium

# === KMS ===
KMS_KEY_ID=arn:aws:kms:us-east-1:ACCOUNT:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
