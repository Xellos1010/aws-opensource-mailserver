# Hoist babel packages for Jest compatibility
public-hoist-pattern[]=*@babel/core*
public-hoist-pattern[]=*@babel/traverse*
public-hoist-pattern[]=*@babel/types*

# Hoist Jest-related packages
public-hoist-pattern[]=*jest*
public-hoist-pattern[]=*ts-jest*

# Enable shamefully-hoist for Jest snapshot compatibility
# Jest's snapshot functionality requires @babel/core to be hoisted
shamefully-hoist=true

