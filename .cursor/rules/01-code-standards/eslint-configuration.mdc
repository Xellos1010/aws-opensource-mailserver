# ESLint Configuration Standards - 2025

Unified ESLint configuration with TypeScript support, security rules, and framework-specific patterns for consistent code quality.

**Justification:** Consistent linting prevents bugs, enforces best practices, ensures code readability, and catches security issues early.

## 🎯 Single Responsibility
This rule ONLY defines ESLint configuration and rules. Not formatting (see prettier-config) or TypeScript compiler options (see typescript-standards).

## 📋 Implementation Checklist

### Initial Setup
```markdown
- [ ] Install ESLint and TypeScript ESLint
- [ ] Configure flat config (ESLint 9+) or classic config
- [ ] Set up TypeScript parser and plugin
- [ ] Configure environment settings
- [ ] Add framework-specific plugins (React, Vue, etc.)
- [ ] Set up security plugins
- [ ] Configure import sorting and validation
- [ ] Add custom rules for project patterns
- [ ] Set up pre-commit hooks
- [ ] Configure IDE integration
```

## 🔧 Flat Config (ESLint 9+)

### Complete Configuration
```javascript
// eslint.config.mjs
import js from '@eslint/js';
import typescript from '@typescript-eslint/eslint-plugin';
import typescriptParser from '@typescript-eslint/parser';
import security from 'eslint-plugin-security';
import importPlugin from 'eslint-plugin-import';
import unicorn from 'eslint-plugin-unicorn';
import sonarjs from 'eslint-plugin-sonarjs';
import prettier from 'eslint-config-prettier';

export default [
  // Base JavaScript rules
  js.configs.recommended,
  
  // Global ignores
  {
    ignores: [
      '**/node_modules/**',
      '**/dist/**',
      '**/build/**',
      '**/.next/**',
      '**/coverage/**',
      '**/*.min.js',
      '**/vendor/**'
    ]
  },

  // TypeScript configuration
  {
    files: ['**/*.ts', '**/*.tsx'],
    languageOptions: {
      parser: typescriptParser,
      parserOptions: {
        ecmaVersion: 'latest',
        sourceType: 'module',
        project: './tsconfig.json',
        tsconfigRootDir: import.meta.dirname,
      },
      globals: {
        console: 'readonly',
        process: 'readonly',
        Buffer: 'readonly',
        __dirname: 'readonly',
        __filename: 'readonly',
      }
    },
    plugins: {
      '@typescript-eslint': typescript,
      'security': security,
      'import': importPlugin,
      'unicorn': unicorn,
      'sonarjs': sonarjs,
    },
    rules: {
      // TypeScript Strict Rules
      '@typescript-eslint/no-explicit-any': 'error',
      '@typescript-eslint/explicit-function-return-type': ['error', {
        allowExpressions: true,
        allowTypedFunctionExpressions: true,
        allowHigherOrderFunctions: true,
      }],
      '@typescript-eslint/no-unused-vars': ['error', {
        argsIgnorePattern: '^_',
        varsIgnorePattern: '^_',
        caughtErrorsIgnorePattern: '^_',
      }],
      '@typescript-eslint/strict-boolean-expressions': ['error', {
        allowString: false,
        allowNumber: false,
        allowNullableObject: false,
      }],
      '@typescript-eslint/no-non-null-assertion': 'error',
      '@typescript-eslint/no-unnecessary-condition': 'error',
      '@typescript-eslint/no-unsafe-assignment': 'error',
      '@typescript-eslint/no-unsafe-member-access': 'error',
      '@typescript-eslint/no-unsafe-call': 'error',
      '@typescript-eslint/no-unsafe-return': 'error',
      '@typescript-eslint/no-floating-promises': 'error',
      '@typescript-eslint/await-thenable': 'error',
      '@typescript-eslint/no-misused-promises': 'error',
      '@typescript-eslint/consistent-type-assertions': ['error', {
        assertionStyle: 'as',
        objectLiteralTypeAssertions: 'never',
      }],
      '@typescript-eslint/consistent-type-imports': ['error', {
        prefer: 'type-imports',
        fixStyle: 'inline-type-imports',
      }],
      
      // Code Quality Rules
      'complexity': ['error', { max: 10 }],
      'max-lines-per-function': ['error', {
        max: 50,
        skipBlankLines: true,
        skipComments: true,
      }],
      'max-depth': ['error', 4],
      'max-nested-callbacks': ['error', 3],
      'no-console': ['warn', {
        allow: ['warn', 'error', 'info']
      }],
      'no-debugger': 'error',
      'no-alert': 'error',
      'no-eval': 'error',
      'no-implied-eval': 'error',
      'no-new-func': 'error',
      'eqeqeq': ['error', 'always'],
      'no-var': 'error',
      'prefer-const': 'error',
      'prefer-template': 'error',
      'no-param-reassign': ['error', {
        props: true,
        ignorePropertyModificationsFor: ['acc', 'req', 'res', 'session']
      }],
      
      // Security Rules
      'security/detect-object-injection': 'warn',
      'security/detect-non-literal-regexp': 'warn',
      'security/detect-unsafe-regex': 'error',
      'security/detect-buffer-noassert': 'error',
      'security/detect-child-process': 'warn',
      'security/detect-disable-mustache-escape': 'error',
      'security/detect-eval-with-expression': 'error',
      'security/detect-no-csrf-before-method-override': 'error',
      'security/detect-non-literal-fs-filename': 'warn',
      'security/detect-non-literal-require': 'warn',
      'security/detect-possible-timing-attacks': 'warn',
      
      // Import Rules
      'import/order': ['error', {
        groups: [
          'builtin',
          'external',
          'internal',
          'parent',
          'sibling',
          'index',
          'object',
          'type'
        ],
        pathGroups: [
          {
            pattern: '@mm/**',
            group: 'internal',
            position: 'before'
          }
        ],
        'newlines-between': 'always',
        alphabetize: {
          order: 'asc',
          caseInsensitive: true
        }
      }],
      'import/no-duplicates': 'error',
      'import/no-cycle': 'error',
      'import/no-unused-modules': ['error', {
        unusedExports: true,
        ignoreExports: ['*.config.ts', '*.config.js', 'index.ts']
      }],
      
      // Unicorn Best Practices
      'unicorn/no-array-callback-reference': 'error',
      'unicorn/no-array-for-each': 'error',
      'unicorn/no-null': 'off', // Too strict for most projects
      'unicorn/prevent-abbreviations': 'off', // Too opinionated
      'unicorn/filename-case': ['error', {
        cases: {
          camelCase: true,
          pascalCase: true,
          kebabCase: true
        }
      }],
      'unicorn/no-abusive-eslint-disable': 'error',
      'unicorn/no-process-exit': 'error',
      'unicorn/prefer-node-protocol': 'error',
      'unicorn/prefer-module': 'error',
      
      // SonarJS Code Quality
      'sonarjs/cognitive-complexity': ['error', 15],
      'sonarjs/no-duplicate-string': ['error', 5],
      'sonarjs/no-identical-functions': 'error',
      'sonarjs/no-collapsible-if': 'error',
      'sonarjs/no-collection-size-mischeck': 'error',
      'sonarjs/no-duplicated-branches': 'error',
      'sonarjs/no-identical-conditions': 'error',
      'sonarjs/no-inverted-boolean-checks': 'error',
      'sonarjs/no-redundant-boolean': 'error',
      'sonarjs/no-unused-collection': 'error',
      'sonarjs/no-useless-catch': 'error',
      'sonarjs/prefer-immediate-return': 'error',
    }
  },

  // JavaScript-specific overrides
  {
    files: ['**/*.js', '**/*.mjs'],
    rules: {
      '@typescript-eslint/no-var-requires': 'off',
    }
  },

  // Test file overrides
  {
    files: ['**/*.spec.ts', '**/*.test.ts', '**/__tests__/**', '**/__it__/**'],
    rules: {
      '@typescript-eslint/no-explicit-any': 'off',
      '@typescript-eslint/no-non-null-assertion': 'off',
      '@typescript-eslint/no-var-requires': 'off', // Allow require() in tests
      'max-lines-per-function': 'off',
      'max-nested-callbacks': 'off',
      'sonarjs/no-duplicate-string': 'off',
      // Node.js built-in modules should use namespace imports
      'import/no-named-as-default': 'error',
      'import/no-named-as-default-member': 'off', // Allow namespace imports
    }
  },

  // Configuration file overrides
  {
    files: ['*.config.ts', '*.config.js', '*.config.mjs'],
    rules: {
      'import/no-default-export': 'off',
      '@typescript-eslint/no-var-requires': 'off',
    }
  },

  // Freshworks FDK specific rules
  {
    files: ['apps/freshsales-*/src/**/*.ts'],
    rules: {
      'no-eval': 'error',
      'no-new-func': 'error',
      'security/detect-eval-with-expression': 'error',
      'no-template-curly-in-string': 'error', // Avoid template literals in injected code
      'unicorn/no-hex-escape': 'error', // Avoid unicode in strings
      'prefer-template': 'off', // Use concatenation in injected scripts
    }
  },

  // Node.js built-in module handling
  {
    files: ['**/*.ts', '**/*.js'],
    rules: {
      // Node.js built-ins should use namespace imports in ES modules
      'import/no-named-as-default': 'error',
      'import/no-named-as-default-member': 'off',
    }
  },

  // Prettier compatibility (must be last)
  prettier,
];
```

