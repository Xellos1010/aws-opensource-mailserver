## 🚨 Common ESLint Issues & Solutions

```typescript
// ❌ Issue: Unexpected any
function process(data: any) { // Error: no-explicit-any
  return data;
}

// ✅ Solution: Use proper types or unknown
function process(data: unknown): ProcessedData {
  if (isValidData(data)) {
    return data as ProcessedData;
  }
  throw new Error('Invalid data');
}

// ❌ Issue: Floating promises
async function main() {
  doAsyncWork(); // Error: no-floating-promises
}

// ✅ Solution: Await or explicitly handle
async function main() {
  await doAsyncWork();
  // or
  void doAsyncWork(); // Explicitly ignore
}

// ❌ Issue: Unsafe member access
function getValue(obj: any) {
  return obj.nested.value; // Error: no-unsafe-member-access
}

// ✅ Solution: Type guards and optional chaining
function getValue(obj: unknown): string | undefined {
  if (isValidObject(obj)) {
    return obj?.nested?.value;
  }
  return undefined;
}
```

