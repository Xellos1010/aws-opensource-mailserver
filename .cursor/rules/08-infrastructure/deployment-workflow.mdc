## 🏭 Phase 3: Production Deployment

**Purpose:** Controlled release to production with safety gates

### Manual Approval Gate
```yaml
# .github/workflows/deploy-production.yml
name: Deploy to Production
on:
  workflow_dispatch:  # Manual trigger
  schedule:
    - cron: '0 10 * * 2,4'  # Auto-deploy Tue/Thu if staging green

jobs:
  deploy-production:
    environment:
      name: production
      url: https://app.example.com
    steps:
      - name: Check staging health
        run: |
          ./scripts/check-staging-health.sh
          if [ $? -ne 0 ]; then
            echo "Staging unhealthy, blocking production deploy"
            exit 1
          fi
      
      - name: Deploy to production
        run: |
          pnpm nx run-many -t deploy --stage=production
          
      - name: Run production smoke tests
        run: pnpm test:e2e:production --smoke-only
      
      - name: Notify team
        if: always()
        run: |
          ./scripts/notify-deployment.sh \
            --status ${{ job.status }} \
            --environment production \
            --version ${{ github.sha }}
```

### Automated Promotion (If Staging Green)
```typescript
// scripts/auto-promote.ts
async function shouldPromoteToProduction(): Promise<boolean> {
  const checks = await Promise.all([
    checkStagingUptime(),      // > 99.9% last 24h
    checkStagingErrors(),       // < 0.1% error rate
    checkStagingPerformance(),  // p95 < 500ms
    checkTestsPassing(),        // All e2e tests green
    checkNoOpenIncidents()      // No P0/P1 incidents
  ]);
  
  return checks.every(check => check === true);
}

if (await shouldPromoteToProduction()) {
  await deployToProduction();
}
```

### Blue-Green Deployment (AWS)
```bash
# Deploy to green environment
./scripts/deploy-webhook-stack.sh up \
  --name production-green \
  --profile prod

# Run smoke tests
pnpm test:e2e:production --target=green

# Switch traffic
aws elbv2 modify-listener \
  --listener-arn $PROD_LISTENER_ARN \
  --default-actions Type=forward,TargetGroupArn=$GREEN_TG_ARN

# Keep blue for rollback
```

