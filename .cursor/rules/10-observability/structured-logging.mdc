## ✅ Testing Logs

### Unit Test Example
```typescript
describe('Logger', () => {
  it('should include correlation ID in all logs', () => {
    const correlationId = 'test-correlation-id';
    const spy = jest.spyOn(console, 'log');
    
    logger.info('Test message', { correlationId });
    
    expect(spy).toHaveBeenCalledWith(
      expect.stringContaining(correlationId)
    );
  });
  
  it('should redact sensitive information', () => {
    const sensitiveData = {
      email: 'user@example.com',
      password: 'secret123'
    };
    
    const logged = logger.formatLog('Test', sensitiveData);
    
    expect(logged).not.toContain('user@example.com');
    expect(logged).not.toContain('secret123');
    expect(logged).toContain('[REDACTED]');
  });
});
```

## 🚨 Anti-Patterns to Avoid

```typescript
// ❌ BAD: Unstructured string concatenation
console.log('User ' + userId + ' logged in at ' + new Date());

// ❌ BAD: Logging sensitive data
logger.info('Login attempt', { password: userPassword });

// ❌ BAD: Missing correlation ID
logger.error('Database error', { error: err });

// ❌ BAD: Synchronous logging in hot path
fs.appendFileSync('app.log', logMessage);

// ✅ GOOD: Structured, async, correlated, redacted
logger.info('User login', {
  userId: hashUserId(userId),
  correlationId,
  timestamp: new Date().toISOString()
});
```

