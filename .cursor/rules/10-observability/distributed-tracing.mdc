### Tracer Initialization
```typescript
// tracing.ts - Initialize BEFORE importing other modules
import { NodeSDK } from '@opentelemetry/sdk-node';
import { getNodeAutoInstrumentations } from '@opentelemetry/auto-instrumentations-node';
import { Resource } from '@opentelemetry/resources';
import { SemanticResourceAttributes } from '@opentelemetry/semantic-conventions';
import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-http';
import { BatchSpanProcessor } from '@opentelemetry/sdk-trace-base';
import { trace, context, SpanStatusCode, SpanKind } from '@opentelemetry/api';

// Configure resource attributes
const resource = new Resource({
  [SemanticResourceAttributes.SERVICE_NAME]: process.env.SERVICE_NAME || 'unknown-service',
  [SemanticResourceAttributes.SERVICE_VERSION]: process.env.npm_package_version || '0.0.0',
  [SemanticResourceAttributes.DEPLOYMENT_ENVIRONMENT]: process.env.NODE_ENV || 'development',
  [SemanticResourceAttributes.SERVICE_NAMESPACE]: 'freshsales-app',
  [SemanticResourceAttributes.SERVICE_INSTANCE_ID]: process.env.HOSTNAME || 'local',
});

// Configure trace exporter
const traceExporter = new OTLPTraceExporter({
  url: process.env.OTEL_EXPORTER_OTLP_ENDPOINT || 'http://localhost:4318/v1/traces',
  headers: {
    'x-api-key': process.env.OTEL_API_KEY || '',
  },
});

// Initialize SDK
const sdk = new NodeSDK({
  resource,
  spanProcessor: new BatchSpanProcessor(traceExporter),
  instrumentations: [
    getNodeAutoInstrumentations({
      '@opentelemetry/instrumentation-fs': {
        enabled: false, // Too noisy
      },
    }),
  ],
});

// Start SDK
sdk.start()
  .then(() => console.log('Tracing initialized'))
  .catch((error) => console.error('Error initializing tracing', error));

// Graceful shutdown
process.on('SIGTERM', () => {
  sdk.shutdown()
    .then(() => console.log('Tracing terminated'))
    .catch((error) => console.error('Error terminating tracing', error))
    .finally(() => process.exit(0));
});

export const tracer = trace.getTracer(
  process.env.SERVICE_NAME || 'app',
  process.env.npm_package_version || '0.0.0'
);
```

## 🎯 Manual Instrumentation Patterns

### Basic Span Creation
```typescript
import { tracer } from './tracing';
import { SpanStatusCode, SpanKind } from '@opentelemetry/api';

async function processOrder(orderId: string) {
  // Start a new span
  return tracer.startActiveSpan('process-order', {
    kind: SpanKind.INTERNAL,
    attributes: {
      'order.id': orderId,
      'order.source': 'web',
    },
  }, async (span) => {
    try {
      // Add events
      span.addEvent('order-validation-started');
      
      // Business logic
      const order = await validateOrder(orderId);
      
      // Add more attributes
      span.setAttributes({
        'order.total': order.total,
        'order.items': order.items.length,
        'order.customer_id': order.customerId,
      });
      
      span.addEvent('order-validation-completed');
      
      // Process payment in nested span
      await tracer.startActiveSpan('process-payment', async (paymentSpan) => {
        try {
          const result = await processPayment(order);
          paymentSpan.setStatus({ code: SpanStatusCode.OK });
          return result;
        } catch (error) {
          paymentSpan.recordException(error);
          paymentSpan.setStatus({ 
            code: SpanStatusCode.ERROR,
            message: error.message 
          });
          throw error;
        } finally {
          paymentSpan.end();
        }
      });
      
      span.setStatus({ code: SpanStatusCode.OK });
      return order;
      
    } catch (error) {
      // Record exception
      span.recordException(error);
      span.setStatus({ 
        code: SpanStatusCode.ERROR,
        message: error.message 
      });
      throw error;
    } finally {
      // Always end the span
      span.end();
    }
  });
}
```

### Database Instrumentation
```typescript
import { SpanKind } from '@opentelemetry/api';

class DatabaseClient {
  async query(sql: string, params: any[] = []) {
    return tracer.startActiveSpan(`db.query`, {
      kind: SpanKind.CLIENT,
      attributes: {
        'db.system': 'postgresql',
        'db.statement': sql.substring(0, 100), // Truncate for safety
        'db.operation': sql.split(' ')[0].toUpperCase(),
        'db.name': process.env.DB_NAME,
        'server.address': process.env.DB_HOST,
        'server.port': process.env.DB_PORT,
      },
    }, async (span) => {
      const startTime = Date.now();
      
      try {
        const result = await this.pool.query(sql, params);
        
        span.setAttributes({
          'db.rows_affected': result.rowCount,
          'db.duration': Date.now() - startTime,
        });
        
        span.setStatus({ code: SpanStatusCode.OK });
        return result;
        
      } catch (error) {
        span.recordException(error);
        span.setStatus({ 
          code: SpanStatusCode.ERROR,
          message: `Database error: ${error.message}`
        });
        throw error;
      } finally {
        span.end();
      }
    });
  }
}
```

### HTTP Client Instrumentation
```typescript
import { SpanKind, context, trace, propagation } from '@opentelemetry/api';

async function callExternalAPI(url: string, options: RequestInit = {}) {
  return tracer.startActiveSpan(`http.request`, {
    kind: SpanKind.CLIENT,
    attributes: {
      'http.method': options.method || 'GET',
      'http.url': url,
      'http.target': new URL(url).pathname,
      'server.address': new URL(url).hostname,
    },
  }, async (span) => {
    // Inject trace context into headers
    const headers = new Headers(options.headers);
    propagation.inject(context.active(), headers, {
      set: (carrier, key, value) => carrier.set(key, value),
    });
    
    try {
      const response = await fetch(url, { ...options, headers });
      
      span.setAttributes({
        'http.status_code': response.status,
        'http.response_content_length': response.headers.get('content-length'),
      });
      
      if (response.ok) {
        span.setStatus({ code: SpanStatusCode.OK });
      } else {
        span.setStatus({ code: SpanStatusCode.ERROR });
      }
      
      return response;
      
    } catch (error) {
      span.recordException(error);
      span.setStatus({ 
        code: SpanStatusCode.ERROR,
        message: error.message 
      });
      throw error;
    } finally {
      span.end();
    }
  });
}
```

### Message Queue Instrumentation
```typescript
// Producer
async function publishMessage(topic: string, message: any) {
  return tracer.startActiveSpan(`mq.publish`, {
    kind: SpanKind.PRODUCER,
    attributes: {
      'messaging.system': 'sqs',
      'messaging.destination': topic,
      'messaging.operation': 'publish',
    },
  }, async (span) => {
    // Inject trace context into message
    const carrier = {};
    propagation.inject(context.active(), carrier);
    
    const enrichedMessage = {
      ...message,
      _traceContext: carrier,
    };
    
    try {
      const result = await sqs.sendMessage({
        QueueUrl: topic,
        MessageBody: JSON.stringify(enrichedMessage),
      });
      
      span.setAttributes({
        'messaging.message_id': result.MessageId,
      });
      
      span.setStatus({ code: SpanStatusCode.OK });
      return result;
    } catch (error) {
      span.recordException(error);
      span.setStatus({ code: SpanStatusCode.ERROR });
      throw error;
    } finally {
      span.end();
    }
  });
}

// Consumer
async function consumeMessage(message: any) {
  // Extract trace context from message
  const traceContext = message._traceContext || {};
  const extractedContext = propagation.extract(context.active(), traceContext);
  
  return context.with(extractedContext, () => {
    return tracer.startActiveSpan(`mq.consume`, {
      kind: SpanKind.CONSUMER,
      attributes: {
        'messaging.system': 'sqs',
        'messaging.operation': 'consume',
        'messaging.message_id': message.MessageId,
      },
    }, async (span) => {
      try {
        await processMessage(message);
        span.setStatus({ code: SpanStatusCode.OK });
      } catch (error) {
        span.recordException(error);
        span.setStatus({ code: SpanStatusCode.ERROR });
        throw error;
      } finally {
        span.end();
      }
    });
  });
}
```

## 📊 Sampling Strategies

### Adaptive Sampling
```typescript
import { AlwaysOnSampler, TraceIdRatioBasedSampler, ParentBasedSampler } from '@opentelemetry/sdk-trace-base';

// Development: Sample everything
const devSampler = new AlwaysOnSampler();

// Production: Intelligent sampling
const prodSampler = new ParentBasedSampler({
  root: new TraceIdRatioBasedSampler(0.1), // 10% of new traces
  remoteParentSampled: new AlwaysOnSampler(), // Always sample if parent sampled
  remoteParentNotSampled: new AlwaysOffSampler(), // Never sample if parent not sampled
});

// Custom sampler for important operations
class PrioritySampler {
  shouldSample(context, traceId, spanName, spanKind, attributes) {
    // Always sample errors
    if (attributes['error'] === true) return { decision: SamplingDecision.RECORD_AND_SAMPLE };
    
    // Always sample slow requests
    if (attributes['http.duration'] > 1000) return { decision: SamplingDecision.RECORD_AND_SAMPLE };
    
    // Sample critical business operations
    if (spanName.includes('payment') || spanName.includes('order')) {
      return { decision: SamplingDecision.RECORD_AND_SAMPLE };
    }
    
    // Default sampling
    return new TraceIdRatioBasedSampler(0.01).shouldSample(context, traceId, spanName, spanKind, attributes);
  }
}
```

## 🔍 Context Propagation

### Express Middleware
```typescript
import { context, propagation, trace } from '@opentelemetry/api';

export const tracingMiddleware = (req, res, next) => {
  // Extract trace context from headers
  const extractedContext = propagation.extract(context.active(), req.headers);
  
  // Create a new span for this request
  const span = tracer.startSpan(`${req.method} ${req.path}`, {
    kind: SpanKind.SERVER,
    attributes: {
      'http.method': req.method,
      'http.url': req.url,
      'http.target': req.path,
      'http.host': req.hostname,
      'http.scheme': req.protocol,
      'http.user_agent': req.get('user-agent'),
      'client.address': req.ip,
    },
  }, extractedContext);
  
  // Store span in request for later use
  req.span = span;
  
  // Continue with span context
  context.with(trace.setSpan(extractedContext, span), () => {
    // Capture response
    const originalSend = res.send;
    res.send = function(data) {
      span.setAttributes({
        'http.status_code': res.statusCode,
        'http.response_content_length': Buffer.byteLength(data),
      });
      
      if (res.statusCode >= 400) {
        span.setStatus({ code: SpanStatusCode.ERROR });
      } else {
        span.setStatus({ code: SpanStatusCode.OK });
      }
      
      span.end();
      return originalSend.call(this, data);
    };
    
    next();
  });
};
```

