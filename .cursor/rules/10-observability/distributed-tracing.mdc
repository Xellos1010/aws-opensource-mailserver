## ✅ Testing Traces

```typescript
import { InMemorySpanExporter, SimpleSpanProcessor } from '@opentelemetry/sdk-trace-base';

describe('Tracing', () => {
  let memoryExporter: InMemorySpanExporter;
  
  beforeEach(() => {
    memoryExporter = new InMemorySpanExporter();
    const provider = new NodeTracerProvider();
    provider.addSpanProcessor(new SimpleSpanProcessor(memoryExporter));
    provider.register();
  });
  
  it('should create spans for API calls', async () => {
    await processOrder('123');
    
    const spans = memoryExporter.getFinishedSpans();
    expect(spans).toHaveLength(2);
    expect(spans[0].name).toBe('process-payment');
    expect(spans[1].name).toBe('process-order');
    expect(spans[1].attributes['order.id']).toBe('123');
  });
});
```

## 🚨 Common Issues

```typescript
// ❌ BAD: Starting spans without ending them
const span = tracer.startSpan('operation');
// Missing span.end() - memory leak!

// ❌ BAD: Not propagating context
fetch(url); // Trace context lost

// ❌ BAD: Including sensitive data in spans
span.setAttribute('user.password', password);

// ✅ GOOD: Proper span lifecycle with context
tracer.startActiveSpan('operation', async (span) => {
  try {
    const result = await doWork();
    span.setStatus({ code: SpanStatusCode.OK });
    return result;
  } catch (error) {
    span.recordException(error);
    span.setStatus({ code: SpanStatusCode.ERROR });
    throw error;
  } finally {
    span.end();
  }
});
```

