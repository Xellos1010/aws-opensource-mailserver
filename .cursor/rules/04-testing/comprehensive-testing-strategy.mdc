### ES Module Handling in Tests

#### Node.js Built-in Module Imports
```typescript
// ❌ Incorrect - ES module syntax for Node.js built-ins
import fs from 'fs';
import path from 'path';
import http from 'http';

// ✅ Correct - Namespace imports for Node.js built-ins
import * as fs from 'fs';
import * as path from 'path';
import * as http from 'http';
```

#### Import.meta.url Fallback
```typescript
// Handle import.meta.url for both build and test environments
const currentDir = typeof import.meta !== 'undefined' && import.meta.url
  ? path.dirname(fileURLToPath(import.meta.url))
  : path.dirname(__filename);
```

### Constructor and Dependency Testing

#### Testing Classes with Dependencies
```typescript
// ❌ Incorrect - Testing implementation details
describe('MyService', () => {
  it('should call logger.info', () => {
    const service = new MyService(logger, db);
    service.doWork();
    expect(logger.info).toHaveBeenCalled();
  });
});

// ✅ Correct - Test behavior, not implementation
describe('MyService', () => {
  let mockLogger: Logger;
  let mockDb: Database;
  let service: MyService;

  beforeEach(() => {
    mockLogger = {
      info: jest.fn(),
      error: jest.fn(),
      child: jest.fn().mockReturnValue({
        info: jest.fn(),
        error: jest.fn(),
      }),
    } as any;

    mockDb = { query: jest.fn() } as any;
    service = new MyService(mockLogger, mockDb);
  });

  it('should perform work successfully', async () => {
    mockDb.query.mockResolvedValue([{ id: 1 }]);
    const result = await service.doWork();
    expect(result).toEqual([{ id: 1 }]);
  });
});
```

#### Mocking Complex Dependencies
```typescript
// For classes with complex constructor requirements
jest.mock('../logger', () => ({
  CloudLogger: jest.fn().mockImplementation(() => ({
    info: jest.fn(),
    error: jest.fn(),
    child: jest.fn().mockReturnValue({
      info: jest.fn(),
      error: jest.fn(),
    }),
  })),
}));

jest.mock('../database', () => ({
  DatabaseConnection: jest.fn().mockImplementation(() => ({
    connect: jest.fn(),
    query: jest.fn(),
    disconnect: jest.fn(),
  })),
}));

// Import after mocking
import { MyService } from './my-service';
```

### Testing Anti-Patterns to Avoid

#### Constructor Signature Changes
```typescript
// ❌ Problem - Tests break when constructor changes
it('should work', () => {
  const service = new Service({ logger, db, config });
});

// ✅ Solution - Use dependency injection with mocks
it('should work', () => {
  const mockLogger = createMockLogger();
  const mockDb = createMockDb();
  const service = new Service(mockLogger, mockDb);
});
```

#### Private Method Testing
```typescript
// ❌ Problem - Testing private methods couples to implementation
it('should validate input', () => {
  const service = new Service();
  (service as any).validateInput('test'); // Accessing private method
});

// ✅ Solution - Test public behavior, not private methods
it('should reject invalid input', async () => {
  const service = new Service();
  await expect(service.processInput('invalid')).rejects.toThrow('Invalid input');
});
```

#### Incorrect Mock Return Types
```typescript
// ❌ Problem - Jest mock typing issues
mockPage.locator().innerText.mockResolvedValue('text'); // Type error

// ✅ Solution - Proper type assertions
mockPage.locator().innerText.mockResolvedValue('text' as any);
```

#### Node.js Built-in Module Imports
```typescript
// ❌ Problem - ES module syntax for Node.js built-ins
import fs from 'fs'; // Fails in test environment

// ✅ Solution - Namespace imports
import * as fs from 'fs';
```

### Unit Test Patterns

#### Testing Pure Functions
```typescript
// math.utils.spec.ts
import { describe, it, expect } from 'vitest';
import { calculateDiscount, validateEmail, formatCurrency } from './utils';

describe('Utils', () => {
  describe('calculateDiscount', () => {
    it('should calculate percentage discount correctly', () => {
      expect(calculateDiscount(100, 10)).toBe(90);
      expect(calculateDiscount(50, 50)).toBe(25);
    });

    it('should handle edge cases', () => {
      expect(calculateDiscount(0, 10)).toBe(0);
      expect(calculateDiscount(100, 0)).toBe(100);
      expect(calculateDiscount(100, 100)).toBe(0);
    });

    it('should throw for invalid inputs', () => {
      expect(() => calculateDiscount(-100, 10)).toThrow('Invalid price');
      expect(() => calculateDiscount(100, -10)).toThrow('Invalid discount');
      expect(() => calculateDiscount(100, 150)).toThrow('Discount exceeds 100%');
    });
  });
});
```

#### Testing Classes with Dependencies
```typescript
// user.service.spec.ts
import { describe, it, expect, beforeEach, vi } from 'vitest';
import { UserService } from './user.service';
import { UserRepository } from './user.repository';
import { EmailService } from './email.service';

vi.mock('./user.repository');
vi.mock('./email.service');

describe('UserService', () => {
  let service: UserService;
  let mockRepository: vi.Mocked<UserRepository>;
  let mockEmailService: vi.Mocked<EmailService>;

  beforeEach(() => {
    mockRepository = vi.mocked(new UserRepository());
    mockEmailService = vi.mocked(new EmailService());
    service = new UserService(mockRepository, mockEmailService);
  });

  describe('createUser', () => {
    it('should create user and send welcome email', async () => {
      const userData = { email: 'test@example.com', name: 'Test User' };
      const createdUser = { id: '123', ...userData };

      mockRepository.create.mockResolvedValue(createdUser);
      mockEmailService.sendWelcomeEmail.mockResolvedValue(true);

      const result = await service.createUser(userData);

      expect(result).toEqual(createdUser);
      expect(mockRepository.create).toHaveBeenCalledWith(userData);
      expect(mockEmailService.sendWelcomeEmail).toHaveBeenCalledWith(userData.email);
    });

    it('should rollback user creation if email fails', async () => {
      const userData = { email: 'test@example.com', name: 'Test User' };
      const createdUser = { id: '123', ...userData };

      mockRepository.create.mockResolvedValue(createdUser);
      mockEmailService.sendWelcomeEmail.mockRejectedValue(new Error('Email failed'));
      mockRepository.delete.mockResolvedValue(true);

      await expect(service.createUser(userData)).rejects.toThrow('User creation failed');
      expect(mockRepository.delete).toHaveBeenCalledWith('123');
    });
  });
});
```

#### Testing Async Operations
```typescript
// api.client.spec.ts
import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import { ApiClient } from './api.client';

describe('ApiClient', () => {
  let client: ApiClient;

  beforeEach(() => {
    client = new ApiClient('https://api.example.com');
    vi.useFakeTimers();
  });

  afterEach(() => {
    vi.useRealTimers();
    vi.restoreAllMocks();
  });

  it('should retry failed requests with exponential backoff', async () => {
    const fetchSpy = vi.spyOn(global, 'fetch');
    fetchSpy
      .mockRejectedValueOnce(new Error('Network error'))
      .mockRejectedValueOnce(new Error('Network error'))
      .mockResolvedValueOnce(new Response(JSON.stringify({ data: 'success' })));

    const promise = client.get('/endpoint');
    
    // Fast-forward through retries
    await vi.advanceTimersByTimeAsync(1000); // First retry
    await vi.advanceTimersByTimeAsync(2000); // Second retry
    
    const result = await promise;
    
    expect(result).toEqual({ data: 'success' });
    expect(fetchSpy).toHaveBeenCalledTimes(3);
  });

  it('should timeout long requests', async () => {
    const fetchSpy = vi.spyOn(global, 'fetch');
    fetchSpy.mockImplementation(() => new Promise(() => {})); // Never resolves

    const promise = client.get('/endpoint', { timeout: 5000 });
    
    await vi.advanceTimersByTimeAsync(5000);
    
    await expect(promise).rejects.toThrow('Request timeout');
  });
});
```

## 🔗 Integration Testing (Middle Layer)

### Database Integration Tests
```typescript
// user.repository.integration.spec.ts
import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';
import { UserRepository } from './user.repository';
import { TestDatabase } from '../test-utils/test-database';

describe('UserRepository Integration', () => {
  let repository: UserRepository;
  let testDb: TestDatabase;

  beforeAll(async () => {
    testDb = await TestDatabase.create();
    repository = new UserRepository(testDb.connection);
  });

  afterAll(async () => {
    await testDb.destroy();
  });

  beforeEach(async () => {
    await testDb.clear();
  });

  it('should create and retrieve user', async () => {
    const userData = {
      email: 'test@example.com',
      name: 'Test User',
      age: 25,
    };

    const created = await repository.create(userData);
    expect(created.id).toBeDefined();

    const retrieved = await repository.findById(created.id);
    expect(retrieved).toMatchObject(userData);
  });

  it('should handle concurrent creates with unique constraint', async () => {
    const email = 'unique@example.com';
    
    const promises = Array(5).fill(null).map(() => 
      repository.create({ email, name: 'Test' })
    );

    const results = await Promise.allSettled(promises);
    
    const successful = results.filter(r => r.status === 'fulfilled');
    const failed = results.filter(r => r.status === 'rejected');
    
    expect(successful).toHaveLength(1);
    expect(failed).toHaveLength(4);
    expect(failed[0].reason).toMatch(/unique constraint/i);
  });
});
```

### API Integration Tests
```typescript
// api.integration.spec.ts
import { describe, it, expect, beforeAll, afterAll } from 'vitest';
import { createApp } from './app';
import request from 'supertest';
import { MockAuthService } from '../test-utils/mock-auth';

describe('API Integration', () => {
  let app: any;
  let authService: MockAuthService;

  beforeAll(async () => {
    authService = new MockAuthService();
    app = await createApp({ authService });
  });

  afterAll(async () => {
    await app.close();
  });

  describe('POST /api/orders', () => {
    it('should create order with valid auth token', async () => {
      const token = authService.generateToken({ userId: '123' });
      
      const response = await request(app)
        .post('/api/orders')
        .set('Authorization', `Bearer ${token}`)
        .send({
          items: [{ productId: 'ABC', quantity: 2 }],
          shippingAddress: '123 Main St',
        });

      expect(response.status).toBe(201);
      expect(response.body).toHaveProperty('orderId');
      expect(response.body).toHaveProperty('status', 'pending');
    });

    it('should reject order without auth', async () => {
      const response = await request(app)
        .post('/api/orders')
        .send({ items: [] });

      expect(response.status).toBe(401);
      expect(response.body.error).toBe('Unauthorized');
    });
  });
});
```

