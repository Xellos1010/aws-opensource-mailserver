### Unit Test Patterns

#### Testing Pure Functions
```typescript
// math.utils.spec.ts
import { describe, it, expect } from 'vitest';
import { calculateDiscount, validateEmail, formatCurrency } from './utils';

describe('Utils', () => {
  describe('calculateDiscount', () => {
    it('should calculate percentage discount correctly', () => {
      expect(calculateDiscount(100, 10)).toBe(90);
      expect(calculateDiscount(50, 50)).toBe(25);
    });

    it('should handle edge cases', () => {
      expect(calculateDiscount(0, 10)).toBe(0);
      expect(calculateDiscount(100, 0)).toBe(100);
      expect(calculateDiscount(100, 100)).toBe(0);
    });

    it('should throw for invalid inputs', () => {
      expect(() => calculateDiscount(-100, 10)).toThrow('Invalid price');
      expect(() => calculateDiscount(100, -10)).toThrow('Invalid discount');
      expect(() => calculateDiscount(100, 150)).toThrow('Discount exceeds 100%');
    });
  });
});
```

#### Testing Classes with Dependencies
```typescript
// user.service.spec.ts
import { describe, it, expect, beforeEach, vi } from 'vitest';
import { UserService } from './user.service';
import { UserRepository } from './user.repository';
import { EmailService } from './email.service';

vi.mock('./user.repository');
vi.mock('./email.service');

describe('UserService', () => {
  let service: UserService;
  let mockRepository: vi.Mocked<UserRepository>;
  let mockEmailService: vi.Mocked<EmailService>;

  beforeEach(() => {
    mockRepository = vi.mocked(new UserRepository());
    mockEmailService = vi.mocked(new EmailService());
    service = new UserService(mockRepository, mockEmailService);
  });

  describe('createUser', () => {
    it('should create user and send welcome email', async () => {
      const userData = { email: 'test@example.com', name: 'Test User' };
      const createdUser = { id: '123', ...userData };

      mockRepository.create.mockResolvedValue(createdUser);
      mockEmailService.sendWelcomeEmail.mockResolvedValue(true);

      const result = await service.createUser(userData);

      expect(result).toEqual(createdUser);
      expect(mockRepository.create).toHaveBeenCalledWith(userData);
      expect(mockEmailService.sendWelcomeEmail).toHaveBeenCalledWith(userData.email);
    });

    it('should rollback user creation if email fails', async () => {
      const userData = { email: 'test@example.com', name: 'Test User' };
      const createdUser = { id: '123', ...userData };

      mockRepository.create.mockResolvedValue(createdUser);
      mockEmailService.sendWelcomeEmail.mockRejectedValue(new Error('Email failed'));
      mockRepository.delete.mockResolvedValue(true);

      await expect(service.createUser(userData)).rejects.toThrow('User creation failed');
      expect(mockRepository.delete).toHaveBeenCalledWith('123');
    });
  });
});
```

#### Testing Async Operations
```typescript
// api.client.spec.ts
import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import { ApiClient } from './api.client';

describe('ApiClient', () => {
  let client: ApiClient;

  beforeEach(() => {
    client = new ApiClient('https://api.example.com');
    vi.useFakeTimers();
  });

  afterEach(() => {
    vi.useRealTimers();
    vi.restoreAllMocks();
  });

  it('should retry failed requests with exponential backoff', async () => {
    const fetchSpy = vi.spyOn(global, 'fetch');
    fetchSpy
      .mockRejectedValueOnce(new Error('Network error'))
      .mockRejectedValueOnce(new Error('Network error'))
      .mockResolvedValueOnce(new Response(JSON.stringify({ data: 'success' })));

    const promise = client.get('/endpoint');
    
    // Fast-forward through retries
    await vi.advanceTimersByTimeAsync(1000); // First retry
    await vi.advanceTimersByTimeAsync(2000); // Second retry
    
    const result = await promise;
    
    expect(result).toEqual({ data: 'success' });
    expect(fetchSpy).toHaveBeenCalledTimes(3);
  });

  it('should timeout long requests', async () => {
    const fetchSpy = vi.spyOn(global, 'fetch');
    fetchSpy.mockImplementation(() => new Promise(() => {})); // Never resolves

    const promise = client.get('/endpoint', { timeout: 5000 });
    
    await vi.advanceTimersByTimeAsync(5000);
    
    await expect(promise).rejects.toThrow('Request timeout');
  });
});
```

#### Testing Error Handling & Propagation Chains

**Critical:** Error handling must be tested at every layer to ensure errors propagate correctly and maintain structure.

##### HTTP Interceptor Error Tests
```typescript
// error.interceptor.spec.ts (Angular/React)
import { TestBed } from '@angular/core/testing';
import { HttpClientTestingModule, HttpTestingController } from '@angular/common/http/testing';
import { HTTP_INTERCEPTORS, HttpClient, HttpErrorResponse } from '@angular/common/http';
import { ErrorInterceptor } from './error.interceptor';

describe('ErrorInterceptor', () => {
  let httpMock: HttpTestingController;
  let httpClient: HttpClient;

  beforeEach(() => {
    TestBed.configureTestingModule({
      imports: [HttpClientTestingModule],
      providers: [
        {
          provide: HTTP_INTERCEPTORS,
          useClass: ErrorInterceptor,
          multi: true,
        },
      ],
    });

    httpMock = TestBed.inject(HttpTestingController);
    httpClient = TestBed.inject(HttpClient);
  });

  describe('error object structure', () => {
    it('should create error with userMessage and recoverable properties', (done) => {
      httpClient.get('/api/test').subscribe({
        next: () => fail('should have failed'),
        error: (error) => {
          // CRITICAL: Verify error structure is correct
          expect(error).toBeInstanceOf(HttpErrorResponse);
          expect(error.userMessage).toBeDefined();
          expect(typeof error.userMessage).toBe('string');
          expect(error.recoverable).toBeDefined();
          expect(typeof error.recoverable).toBe('boolean');
          expect(error.status).toBe(500);
          done();
        },
      });

      const req = httpMock.expectOne('/api/test');
      req.flush({ error: 'Server error' }, { status: 500, statusText: 'Internal Server Error' });
    });

    it('should preserve original error properties', (done) => {
      httpClient.get('/api/test').subscribe({
        next: () => fail('should have failed'),
        error: (error) => {
          expect(error.status).toBe(404);
          expect(error.statusText).toBe('Not Found');
          expect(error.url).toContain('/api/test');
          expect(error.userMessage).toBeDefined();
          done();
        },
      });

      const req = httpMock.expectOne('/api/test');
      req.flush({}, { status: 404, statusText: 'Not Found' });
    });

    it('should handle network errors (status 0)', (done) => {
      httpClient.get('/api/test').subscribe({
        next: () => fail('should have failed'),
        error: (error) => {
          expect(error.status).toBe(0);
          expect(error.userMessage).toContain('connect');
          expect(error.recoverable).toBe(true);
          done();
        },
      });

      const req = httpMock.expectOne('/api/test');
      req.error(new ErrorEvent('Network error'));
    });
  });

  describe('error extraction downstream', () => {
    it('should allow error message extraction in catch blocks', async () => {
      let extractedMessage = '';
      let extractedStatus: number | undefined;

      try {
        await httpClient.get('/api/test').toPromise();
      } catch (error) {
        // Test the actual extraction pattern used in components
        if (error && typeof error === 'object') {
          const err = error as { userMessage?: string; message?: string; status?: number };
          extractedMessage = err.userMessage || err.message || 'Unknown error';
          extractedStatus = err.status;
        }
      }

      const req = httpMock.expectOne('/api/test');
      req.flush({ error: 'Test error' }, { status: 500, statusText: 'Server Error' });

      // Wait for error to propagate
      await new Promise(resolve => setTimeout(resolve, 10));

      expect(extractedMessage).toBeTruthy();
      expect(extractedStatus).toBe(500);
    });
  });
});
```

##### Error Service Tests - All Error Types
```typescript
// error.service.spec.ts
import { ErrorService } from './error.service';
import { HttpErrorResponse } from '@angular/common/http';

describe('ErrorService', () => {
  let service: ErrorService;

  beforeEach(() => {
    service = new ErrorService();
  });

  describe('setHttpError - error type handling', () => {
    it('should handle HttpErrorResponse with userMessage', (done) => {
      const httpError = Object.assign(
        new HttpErrorResponse({ status: 500, statusText: 'Server Error' }),
        { userMessage: 'User-friendly message', recoverable: true }
      );

      service.setHttpError(httpError);
      service.getCurrentError().pipe(take(1)).subscribe((error) => {
        expect(error?.message).toBe('User-friendly message');
        expect(error?.recoverable).toBe(true);
        done();
      });
    });

    it('should handle HttpErrorResponse with nested error.error', (done) => {
      const httpError = new HttpErrorResponse({
        status: 500,
        statusText: 'Server Error',
        error: { error: 'Nested error message' }
      });

      service.setHttpError(httpError);
      service.getCurrentError().pipe(take(1)).subscribe((error) => {
        expect(error?.message).toContain('Nested error message');
        done();
      });
    });

    it('should handle HttpErrorResponse with nested error.message', (done) => {
      const httpError = new HttpErrorResponse({
        status: 500,
        statusText: 'Server Error',
        error: { message: 'Nested message' }
      });

      service.setHttpError(httpError);
      service.getCurrentError().pipe(take(1)).subscribe((error) => {
        expect(error?.message).toContain('Nested message');
        done();
      });
    });

    it('should handle plain Error instances', (done) => {
      const error = new Error('Plain error message');
      service.setHttpError(error);
      service.getCurrentError().pipe(take(1)).subscribe((error) => {
        expect(error?.message).toBe('Plain error message');
        expect(error?.recoverable).toBe(true); // Network/timeout errors are recoverable
        done();
      });
    });

    it('should handle string errors', (done) => {
      service.setHttpError('String error');
      service.getCurrentError().pipe(take(1)).subscribe((error) => {
        expect(error?.message).toBe('String error');
        done();
      });
    });

    it('should handle errors with status 0 (network errors)', (done) => {
      const httpError = Object.assign(
        new HttpErrorResponse({ status: 0, statusText: 'Unknown Error' }),
        { userMessage: 'Network error', recoverable: true }
      );

      service.setHttpError(httpError);
      service.getCurrentError().pipe(take(1)).subscribe((error) => {
        expect(error?.message).toContain('Network error');
        expect(error?.recoverable).toBe(true);
        done();
      });
    });

    it('should handle unknown error types gracefully', (done) => {
      service.setHttpError(null as unknown);
      service.getCurrentError().pipe(take(1)).subscribe((error) => {
        expect(error?.message).toBe('An unexpected error occurred');
        done();
      });
    });
  });
});
```

##### Component Error Handling Tests
```typescript
// search.page.spec.ts
import { ComponentFixture, TestBed } from '@angular/core/testing';
import { HttpClientTestingModule } from '@angular/common/http/testing';
import { SearchPage } from './search.page';
import { ErrorService } from 'src/services/error/error.service';
import { LoggingService } from 'src/services/logging/logging.service';
import { HttpErrorResponse } from '@angular/common/http';

describe('SearchPage - Error Handling', () => {
  let component: SearchPage;
  let fixture: ComponentFixture<SearchPage>;
  let errorService: jasmine.SpyObj<ErrorService>;
  let loggingService: jasmine.SpyObj<LoggingService>;

  beforeEach(() => {
    errorService = jasmine.createSpyObj('ErrorService', ['setHttpError']);
    loggingService = jasmine.createSpyObj('LoggingService', ['error']);

    TestBed.configureTestingModule({
      imports: [HttpClientTestingModule],
      declarations: [SearchPage],
      providers: [
        { provide: ErrorService, useValue: errorService },
        { provide: LoggingService, useValue: loggingService },
      ],
    });

    fixture = TestBed.createComponent(SearchPage);
    component = fixture.componentInstance;
  });

  describe('error extraction in catch blocks', () => {
    it('should extract userMessage from HttpErrorResponse', async () => {
      const httpError = Object.assign(
        new HttpErrorResponse({ status: 500, statusText: 'Server Error' }),
        { userMessage: 'User-friendly error', recoverable: true }
      );

      // Mock the service to throw the error
      spyOn(component.indeedClient, 'getSearchFirstPage').and.returnValue(
        Promise.reject(httpError)
      );

      await component.search();

      // Verify error was logged with correct message
      expect(loggingService.error).toHaveBeenCalledWith(
        'Search failed',
        jasmine.objectContaining({
          error: 'User-friendly error',
          status: 500,
        })
      );

      // Verify error service was called
      expect(errorService.setHttpError).toHaveBeenCalledWith(
        httpError,
        jasmine.any(Function)
      );
    });

    it('should extract message from nested error.error', async () => {
      const httpError = new HttpErrorResponse({
        status: 500,
        statusText: 'Server Error',
        error: { error: 'Nested error message' }
      });

      spyOn(component.indeedClient, 'getSearchFirstPage').and.returnValue(
        Promise.reject(httpError)
      );

      await component.search();

      expect(loggingService.error).toHaveBeenCalledWith(
        'Search failed',
        jasmine.objectContaining({
          error: jasmine.stringContaining('Nested error message'),
        })
      );
    });

    it('should handle Error instances', async () => {
      const error = new Error('Plain error');
      spyOn(component.indeedClient, 'getSearchFirstPage').and.returnValue(
        Promise.reject(error)
      );

      await component.search();

      expect(loggingService.error).toHaveBeenCalledWith(
        'Search failed',
        jasmine.objectContaining({
          error: 'Plain error',
        })
      );
    });

    it('should handle string errors', async () => {
      spyOn(component.indeedClient, 'getSearchFirstPage').and.returnValue(
        Promise.reject('String error')
      );

      await component.search();

      expect(loggingService.error).toHaveBeenCalledWith(
        'Search failed',
