```

## Sidepanel Log Display

### Live Tail

Sidepanel should show live tail of run logs:

```typescript
function useRunLog(runId: string) {
  const [logs, setLogs] = useState<LogEntry[]>([]);

  useEffect(() => {
    // Load initial logs
    chrome.storage.session.get(`run_log:${runId}`).then(result => {
      setLogs(result[`run_log:${runId}`] || []);
    });

    // Subscribe to updates
    const listener = (changes: { [key: string]: chrome.storage.StorageChange }) => {
      if (changes[`run_log:${runId}`]) {
        setLogs(changes[`run_log:${runId}`].newValue || []);
      }
    };

    chrome.storage.onChanged.addListener(listener);
    return () => chrome.storage.onChanged.removeListener(listener);
  }, [runId]);

  return logs;
}
```

### Log Export

Export run log as JSON:

```typescript
async function exportRunLog(runId: string): Promise<string> {
  const result = await chrome.storage.session.get(`run_log:${runId}`);
  const logs = result[`run_log:${runId}`] || [];
  
  return JSON.stringify(logs, null, 2);
}
```

## PHI-Safe Logging

### Redaction

Never log PHI in plaintext:

```typescript
function redactUrl(url: string): string {
  // Mask URLs in PHI mode
  if (phiMode) {
    return '[REDACTED]';
  }
  return url;
}

logger.info('Navigation', {
  url: redactUrl(url),
  correlationId,
});
```

### Secure Logging

```typescript
// Store sensitive logs in secure storage
if (phiMode) {
  await secureStorage.append('secure_log', logEntry);
} else {
  await appendToRunLog(runId, logEntry);
}
```

## Performance Logging

### Duration Tracking

```typescript
const startTime = Date.now();

// ... operation ...

logger.info('Operation completed', {
  operation: 'executeRecipe',
  duration: Date.now() - startTime,
  correlationId,
});
```

### Metrics

```typescript
logger.info('Metrics', {
  operation: 'batchRun',
  metrics: {
    totalTasks: 100,
    completedTasks: 95,
    failedTasks: 3,
    deferredTasks: 2,
    averageTaskDuration: 5000,
    totalDuration: 500000,
