## Examples

### ✅ Good: Complete Mock Implementation

```typescript
// Top of service_worker/index.ts
if (typeof window === 'undefined') {
  (globalThis as any).window = {
    dispatchEvent: () => true,
    addEventListener: () => {},
    removeEventListener: () => {},
    postMessage: () => {},
    location: { href: '', origin: '', /* ... */ },
  } as Window;
}

if (typeof document === 'undefined') {
  const createMockElement = () => ({
    appendChild: () => ({} as Node),
    removeChild: () => ({} as Node),
    querySelector: () => null,
    querySelectorAll: () => [],
    // ... other methods
  } as HTMLElement);

  (globalThis as any).document = {
    body: createMockElement(),
    head: createMockElement(),
    documentElement: createMockElement(),
    querySelector: () => null,
    querySelectorAll: () => [],
    createElement: () => createMockElement(),
    // ... other methods
  } as Document;
}

// Now imports are safe
import { bootstrapBackground } from '@chrome-ext/core-runtime';
```

### ❌ Bad: Missing Required Methods

```typescript
// Missing appendChild support
if (typeof document === 'undefined') {
  (globalThis as any).document = {
    querySelector: () => null,
    // ❌ Missing body, head, documentElement
    // ❌ createElement doesn't return element with appendChild
  } as Document;
}
```

